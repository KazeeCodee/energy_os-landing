---
import { Image } from "astro:assets";
import logoFull from "../../assets/logo.png";
import kazecode from "../../assets/kazecode_minimal.svg";
---
<footer class="bg-[var(--footer-bg)] pt-32 pb-16 transition-colors duration-300 border-t border-[var(--border)] relative">
  <!-- Separador superior decorativo (Línea central + Glow) -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-forest to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-px bg-forest shadow-[0_0_15px_rgba(22,128,86,0.5)]"></div>

  <div class="container mx-auto px-6">
    <!-- CTA Refinado -->
    <div class="relative max-w-5xl mx-auto text-center mb-32">
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-forest/5 text-forest text-[11px] font-bold uppercase tracking-[0.2em] mb-8 border border-forest/10">
          ¿Listo para optimizar?
        </div>
        
        <h2 class="text-3xl md:text-5xl font-bold mb-8 tracking-tight leading-tight max-w-3xl mx-auto text-[var(--text-main)]">
          Optimice su costo energético con <span class="text-forest font-medium">inteligencia de mercado</span>.
        </h2>
        
        <p class="text-mist text-lg md:text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
          Únase a las empresas que ya transformaron su gestión de datos oficiales en ahorros reales y cumplimiento garantizado.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <a href="#demo" class="w-full sm:w-auto px-10 py-4 bg-forest hover:bg-forest-dark text-white rounded-xl font-bold transition-all shadow-lg shadow-forest/20 hover:scale-105 active:scale-95">
            Empezar prueba gratis
          </a>
          <a href="#contact" class="w-full sm:w-auto px-10 py-4 bg-transparent hover:bg-forest/10 text-[var(--text-main)] border border-forest/20 rounded-xl font-bold transition-all">
            Hablar con un experto
          </a>
        </div>
      </div>
    </div>

    <!-- Links y Branding -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-20 px-4">
      <div class="md:col-span-4 max-w-xs">
        <div class="flex items-center mb-8">
          <Image src={logoFull} alt="EnergyOS Logo" class="logo-light h-14 w-auto object-contain" />
          <Image src={logoFull} alt="EnergyOS Logo" class="logo-dark h-14 w-auto object-contain" />
        </div>

<style>
  .logo-dark {
    display: none;
    filter: brightness(0) invert(1);
  }

  :global(.dark) .logo-dark {
    display: block;
  }

  :global(.dark) .logo-light {
    display: none;
  }

  .social-icon-linkedin {
    color: #0077b5 !important;
  }

  :global(.dark) .social-icon-linkedin {
    color: #ffffff !important;
  }

  :global(.dark) .kazecode-icon {
    filter: brightness(0) invert(1) !important;
  }
</style>
        <p class="text-mist text-sm leading-relaxed mb-6">
          Plataforma líder en inteligencia de mercado para el sector energético argentino. Datos reales, decisiones inteligentes.
        </p>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/company/kazecode" aria-label="LinkedIn" class="w-11 h-11 rounded-2xl bg-white dark:bg-white/10 border border-slate-200 dark:border-white/20 flex items-center justify-center social-icon-linkedin hover:scale-110 transition-all shadow-sm">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="https://kazecode.com.ar/" aria-label="Kazecode" class="w-11 h-11 rounded-2xl bg-white dark:bg-white/10 border border-slate-200 dark:border-white/20 flex items-center justify-center hover:scale-110 transition-all shadow-sm overflow-hidden p-2">
            <img src={kazecode.src} alt="Kazecode Logo" class="w-full h-full object-contain kazecode-icon" />
          </a>
        </div>
      </div>
      
      <div class="md:col-span-2">
        <h4 class="font-bold text-xs uppercase tracking-widest text-[var(--text-main)] mb-6">Plataforma</h4>
        <ul class="space-y-4 text-sm">
          <li><a href="#" class="text-mist hover:text-forest transition-colors">Monitorización</a></li>
          <li><a href="#" class="text-mist hover:text-forest transition-colors">Benchmark</a></li>
          <li><a href="#" class="text-mist hover:text-forest transition-colors">Simulador MEM</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <h4 class="font-bold text-xs uppercase tracking-widest text-[var(--text-main)] mb-6">Compañía</h4>
        <ul class="space-y-4 text-sm">
          <li><a href="#" class="text-mist hover:text-forest transition-colors">Nosotros</a></li>
          <li><a href="#" class="text-mist hover:text-forest transition-colors">Contacto</a></li>
          <li><a href="#" class="text-mist hover:text-forest transition-colors">Legal</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h4 class="font-bold text-xs uppercase tracking-widest text-[var(--text-main)] mb-6">Newsletter</h4>
        <p class="text-mist text-xs mb-4">Reciba nuestro reporte mensual MATER.</p>
        <form id="newsletter-form" class="flex gap-2" novalidate>
          <input
            id="newsletter-email"
            name="email"
            type="email"
            required
            placeholder="Email corporativo"
            class="bg-[var(--background)] border border-[var(--border)] rounded-lg px-4 py-2 text-sm w-full focus:outline-none focus:border-forest transition-colors shadow-sm"
          />
          <button
            id="newsletter-submit"
            type="submit"
            class="bg-forest text-white px-4 rounded-lg hover:bg-forest-dark transition-colors shadow-sm disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center min-w-[44px]"
          >
            <svg id="newsletter-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
            <svg id="newsletter-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path></svg>
          </button>
        </form>
        <p id="newsletter-feedback" class="hidden mt-3 text-xs font-medium" role="status" aria-live="polite"></p>
      </div>
    </div>

    <div class="pt-8 border-t border-[var(--border)] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-mist text-[10px] uppercase tracking-widest font-medium">
        &copy; {new Date().getFullYear()} EnergyOS Argentina.
      </p>
      <div class="flex gap-8">
        <a href="#" class="text-mist text-[10px] uppercase tracking-widest font-medium hover:text-forest transition-colors">Cookies</a>
        <a href="#" class="text-mist text-[10px] uppercase tracking-widest font-medium hover:text-forest transition-colors">Privacidad</a>
      </div>
    </div>
  </div>
</footer>

<script>
  import { supabase } from "../../db/supabase.js";

  const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
  const input = document.getElementById("newsletter-email") as HTMLInputElement | null;
  const submitBtn = document.getElementById("newsletter-submit") as HTMLButtonElement | null;
  const icon = document.getElementById("newsletter-icon");
  const spinner = document.getElementById("newsletter-spinner");
  const feedback = document.getElementById("newsletter-feedback");

  function showFeedback(type: "success" | "error" | "info", msg: string) {
    if (!feedback) return;
    feedback.textContent = msg;
    feedback.classList.remove("hidden");
    const colorClass =
      type === "success"
        ? "text-forest"
        : type === "info"
          ? "text-mist"
          : "text-red-500";
    feedback.className = `mt-3 text-xs font-medium ${colorClass}`;
  }

  function setLoading(loading: boolean) {
    if (!submitBtn || !icon || !spinner) return;
    submitBtn.disabled = loading;
    icon?.classList.toggle("hidden", loading);
    spinner?.classList.toggle("hidden", !loading);
  }

  input?.addEventListener("input", () => {
    feedback?.classList.add("hidden");
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    feedback?.classList.add("hidden");
    if (!input) return;

    const email = input.value.trim();
    if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
      showFeedback("error", "Ingrese un email válido.");
      return;
    }

    setLoading(true);
    const { error } = await supabase
      .from("newsletter_subscribers")
      .insert({ email, source: "footer" });
    setLoading(false);

    if (error) {
      if (error.code === "23505") {
        window.dispatchEvent(
          new CustomEvent("show-feedback-modal", {
            detail: {
              type: "info",
              title: "Ya estás suscrito",
              message: "Este email ya figura en nuestra base de datos. ¡Gracias por tu interés!",
            },
          }) as any
        );
        return;
      }
      console.error("Newsletter insert error:", error);
      window.dispatchEvent(
        new CustomEvent("show-feedback-modal", {
          detail: {
            type: "error",
            title: "Error de suscripción",
            message: "No pudimos procesar tu suscripción en este momento. Por favor, intenta más tarde.",
          },
        }) as any
      );
      return;
    }

    window.dispatchEvent(
      new CustomEvent("show-feedback-modal", {
        detail: {
          type: "success",
          title: "¡Suscripción confirmada!",
          message: "Gracias por unirte a nuestro newsletter. Pronto recibirás nuestras novedades.",
        },
      }) as any
    );
    form?.reset();
  });
</script>
