<div class="bg-[var(--surface)] border-y border-[var(--border)] py-10 relative overflow-hidden">
  <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
    <!-- Item 1 -->
    <div class="flex justify-center md:justify-start">
      <div class="flex items-center gap-4 min-w-[240px] md:min-w-0 group">
        <div class="w-12 h-12 rounded-xl bg-forest/10 flex items-center justify-center text-forest group-hover:scale-110 transition-transform shrink-0 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-7"/><path d="M9 8.5 12 11l3-2.5"/><path d="M12 11V5"/><path d="M12 2a2 2 0 0 1 2 2v2H10V4a2 2 0 0 1 2-2z"/><path d="m20 8-1 1v11a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V9L4 8"/></svg>
        </div>
        <div>
          <div class="font-bold text-lg">Res. 400/2025</div>
          <div class="text-xs text-mist font-medium uppercase tracking-wider">Actualizado al día</div>
        </div>
      </div>
    </div>

    <!-- Item 2 -->
    <div class="flex justify-center md:justify-start">
      <div class="flex items-center gap-4 min-w-[240px] md:min-w-0 group">
        <div class="w-12 h-12 rounded-xl bg-forest/10 flex items-center justify-center text-forest group-hover:scale-110 transition-transform shrink-0 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M12 7l0 5l3 3"/></svg>
        </div>
        <div>
          <div class="font-bold text-lg">Ley 27.191</div>
          <div class="text-xs text-mist font-medium uppercase tracking-wider">Compliance Automático</div>
        </div>
      </div>
    </div>

    <!-- Item 3 -->
    <div class="flex justify-center md:justify-end">
      <div class="flex items-center gap-4 min-w-[240px] md:min-w-0 group">
        <div class="w-12 h-12 rounded-xl bg-forest/10 flex items-center justify-center text-forest group-hover:scale-110 transition-transform shrink-0 shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
        </div>
        <div>
          <div class="font-bold text-lg">Fuentes Oficiales</div>
          <div class="text-xs text-mist font-medium uppercase tracking-wider">Integración de Mercado</div>
        </div>
      </div>
    </div>
  </div>
</div>
