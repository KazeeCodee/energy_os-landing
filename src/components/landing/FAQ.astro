---
const faqs = [
  {
    category: "Implementación",
    items: [
      {
        question: "¿Qué necesito para arrancar?",
        answer:
          "Casi nada. Sin medidores, sin hardware, sin cortes. Empezás en **minutos**, no en meses. La complejidad la absorbemos nosotros.",
      },
      {
        question: "¿Mis datos están seguros?",
        answer:
          "Sí. Tu perfil, tu estrategia y tus contratos quedan **estrictamente confidenciales**. Encriptación de grado bancario sobre todo lo que cargues.",
      },
      {
        question: "¿Cómo se ve la información?",
        answer:
          "Como **decisiones**, no como reportes. Una sola pantalla muestra dónde estás parado, dónde estás expuesto y qué conviene hacer.",
      },
    ],
  },
  {
    category: "Resultado y retorno",
    items: [
      {
        question: "¿Cuánto se recupera con esto?",
        answer:
          "Lo típico: retorno de **30x a 100x** en el primer año. Multas evitadas (entre USD 60k y USD 200k) y sobrecostos en contratos del orden del **15% anual**.",
      },
      {
        question: "¿Cómo sé si estoy pagando de más?",
        answer:
          "Te mostramos cuánto está pagando el mercado, de forma anónima, y dónde está parado tu contrato. **Negociás con información, no con intuición**.",
      },
    ],
  },
  {
    category: "Plataforma y soporte",
    items: [
      {
        question: "¿Sirve para varias plantas?",
        answer:
          "Sí. Una planta o una red entera, en una sola pantalla. Pensado para CFOs y responsables de energía que necesitan ver todo junto.",
      },
      {
        question: "¿Y si comercializo energía?",
        answer:
          "Tenemos un **portal bajo tu marca**. Ofrecés a tu cartera la misma claridad, con tu logo y tu identidad.",
      },
    ],
  },
];

// Generate structured data for SEO
const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.flatMap(category => 
    category.items.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer.replace(/\*\*/g, '')
      }
    }))
  )
};
---

<section id="faq" class="w-full py-24" itemscope itemtype="https://schema.org/FAQPage">
  <div class="container mx-auto px-6 max-w-4xl">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Preguntas <span class="text-forest">Frecuentes</span>
      </h2>
      <p class="text-mist text-lg max-w-2xl mx-auto">
        Lo importante, sin vueltas.
      </p>
    </div>

    <!-- FAQ Categories -->
    <div class="space-y-16">
      {faqs.map((category, categoryIndex) => (
        <div class="faq-category">
          <!-- Category Title -->
          <h3 class="text-xl font-bold mb-8 flex items-center gap-3">
            <span class="w-1.5 h-8 bg-forest rounded-full shadow-[0_0_15px_rgba(22,128,86,0.3)]"></span>
            {category.category}
          </h3>

          <!-- FAQ Items -->
          <div class="faq-items-container border-t border-[var(--border)]">
            {category.items.map((item, itemIndex) => (
              <div 
                class="faq-item border-b border-[var(--border)] group"
                itemscope 
                itemprop="mainEntity" 
                itemtype="https://schema.org/Question"
              >
                <button
                  type="button"
                  class="faq-question w-full text-left py-6 transition-all duration-300"
                  aria-expanded="false"
                  aria-controls={`faq-answer-${categoryIndex}-${itemIndex}`}
                  id={`faq-question-${categoryIndex}-${itemIndex}`}
                >
                  <div class="flex items-center justify-between gap-6">
                    <span class="font-medium text-lg transition-colors group-hover:text-forest" itemprop="name">
                      {item.question}
                    </span>
                    <div class="relative w-5 h-5 flex-shrink-0">
                      <svg 
                        class="faq-icon-down absolute inset-0 w-5 h-5 text-mist transition-all duration-300"
                        xmlns="http://www.w3.org/2000/svg" 
                        fill="none" 
                        viewBox="0 0 24 24" 
                        stroke="currentColor" 
                        stroke-width="2"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                      <svg 
                        class="faq-icon-up absolute inset-0 w-5 h-5 text-forest transition-all duration-300 opacity-0"
                        xmlns="http://www.w3.org/2000/svg" 
                        fill="none" 
                        viewBox="0 0 24 24" 
                        stroke="currentColor" 
                        stroke-width="2"
                        aria-hidden="true"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
                      </svg>
                    </div>
                  </div>
                </button>

                <div
                  class="faq-answer overflow-hidden transition-all duration-300"
                  id={`faq-answer-${categoryIndex}-${itemIndex}`}
                  role="region"
                  style="max-height: 0;"
                  aria-labelledby={`faq-question-${categoryIndex}-${itemIndex}`}
                  itemscope 
                  itemprop="acceptedAnswer" 
                  itemtype="https://schema.org/Answer"
                >
                  <div class="pb-6">
                    <p class="text-mist leading-relaxed text-base" itemprop="text" set:html={item.answer.replace(/\*\*(.*?)\*\*/g, '<strong class="text-[var(--text-main)] font-semibold">$1</strong>')} />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />
</section>

<style>
  @reference "../../styles/global.css";

  .faq-item.active .faq-icon-down {
    opacity: 0;
    transform: translateY(-4px);
  }

  .faq-item.active .faq-icon-up {
    opacity: 1;
    transform: translateY(0);
  }

  .faq-answer {
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-question:focus-visible {
    @apply outline-2 outline-forest outline-offset-4 rounded-lg;
  }
</style>

<script>
  function initFAQ() {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach((item) => {
      const button = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      
      if (!button || !answer) return;

      button.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        
        // Close all other items
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('active');
            const otherBtn = otherItem.querySelector('.faq-question');
            const otherAns = otherItem.querySelector('.faq-answer') as HTMLElement;
            if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
            if (otherAns) otherAns.style.maxHeight = '0';
          }
        });

        // Toggle current item
        item.classList.toggle('active');
        const nowActive = item.classList.contains('active');
        button.setAttribute('aria-expanded', nowActive ? 'true' : 'false');
        
        if (nowActive) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
        } else {
          answer.style.maxHeight = '0';
        }
      });
    });
  }

  initFAQ();
  document.addEventListener('astro:page-load', initFAQ);
</script>
