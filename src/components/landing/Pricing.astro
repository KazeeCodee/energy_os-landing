---
import { Image } from "astro:assets";

const features = [
  "Cumplimiento en vivo, sin sorpresas",
  "Alertas antes de que el problema sea plata",
  "Benchmark real de lo que paga el mercado",
  "Proyección de costos para tu próximo trimestre",
  "Una sola pantalla para toda la operación",
  "Tus datos, exportables cuando quieras",
  "Soporte directo, sin filtros"
];

// Cálculo de precios
const annualPrice = 8000;
const annualMonthlyEquivalent = Math.round((annualPrice / 12) * 100) / 100;
const monthlyPrice = Math.round(( (annualPrice / 12) + (annualPrice * 0.01) ) * 100) / 100; 
---

<section class="py-24 relative overflow-hidden" id="pricing">
  <!-- Dekoración de fondo -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 w-full h-full bg-[radial-gradient(circle_at_center,var(--color-forest-transparent)_0%,transparent_70%)] opacity-20"></div>

  <div class="container mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <h2 class="text-4xl md:text-6xl font-bold mb-6 tracking-tight text-[var(--text-main)]">
        Un solo plan. <span class="inline-block px-1 bg-gradient-to-r from-forest to-cyan-400 bg-clip-text text-transparent italic">Todo claro.</span>
      </h2>
      <p class="text-mist text-lg mb-12">
        Sin letra chica. Sin niveles. Acceso completo a la capa que te saca de operar a ciegas.
      </p>

      <!-- Toggle Switch -->
      <div class="flex items-center justify-center gap-4 mb-16">
        <span id="label-monthly" class="text-sm font-bold transition-colors">Mensual</span>
        <button 
          id="pricing-toggle"
          class="relative w-16 h-8 rounded-full p-1 transition-all focus:outline-none pricing-toggle-btn shadow-inner"
          aria-label="Toggle pricing"
        >
          <div id="toggle-knob" class="w-6 h-6 rounded-full bg-forest shadow-md transition-transform translate-x-0"></div>
        </button>
        <div class="flex items-center gap-2">
          <span id="label-annual" class="text-sm font-bold text-mist transition-colors">Anual</span>
          <span class="px-2 py-0.5 rounded-full bg-forest/10 text-forest text-[10px] font-bold uppercase tracking-wider border border-forest/20">Ahorre 12%</span>
        </div>
      </div>
    </div>

    <!-- Main Pricing Card -->
    <div class="max-w-4xl mx-auto reveal" style="transition-delay: 0.2s;">
      <div class="relative bg-[var(--surface)] border border-[var(--border)] rounded-[3rem] overflow-hidden shadow-2xl backdrop-blur-md group hover:border-forest/30 transition-colors">
        <!-- Glow effect en hover -->
        <div class="absolute -top-[50%] -left-[50%] w-[200%] h-[200%] bg-[radial-gradient(circle,rgba(21,202,202,0.05)_0%,transparent_50%)] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>

        <div class="grid grid-cols-1 md:grid-cols-2">
          <!-- Left: Pricing Info -->
          <div class="p-10 md:p-14 border-b md:border-b-0 md:border-r border-[var(--border)]">
            <div class="mb-8">
              <h3 class="text-2xl font-bold mb-4">Plan Pro Integral</h3>
              <p class="text-mist leading-relaxed">
                Para empresas que se cansaron de descubrir los problemas tarde y de pagar de más sin saberlo.
              </p>
            </div>

            <div class="mb-12">
              <div class="pricing-display flex items-baseline gap-2">
                <span class="text-2xl font-bold text-mist">USD</span>
                <span id="price-value" class="text-6xl md:text-7xl font-bold tracking-tighter transition-all duration-300">{monthlyPrice}</span>
                <span id="price-period" class="text-xl font-bold text-mist transition-all">/mes</span>
              </div>
              <p id="billing-info" class="text-xs text-mist/60 mt-3 font-medium uppercase tracking-widest">Facturado mensualmente</p>
            </div>

            <div class="flex flex-col gap-3">
              <a href="#contacto" class="block w-full py-5 bg-forest hover:bg-forest-dark text-white rounded-2xl font-bold text-center text-lg transition-all shadow-xl shadow-forest/20 hover:scale-[1.02] active:scale-[0.98]">
                Ver cómo está mi operación hoy
              </a>
              <a href="/prueba-gratis" class="block w-full py-4 bg-[var(--surface-hover)] hover:bg-[var(--border)] text-[var(--text-main)] border border-[var(--border)] rounded-2xl font-bold text-center transition-all hover:scale-[1.02] active:scale-[0.98]">
                Iniciar prueba gratuita
              </a>
            </div>
            <p class="text-[10px] text-center text-mist mt-6 uppercase tracking-widest font-semibold">Sin compromiso largo • Cortás cuando quieras</p>
          </div>

          <!-- Right: Features -->
          <div class="p-10 md:p-14 bg-navy/5 dark:bg-white/[0.02]">
            <h4 class="font-bold text-sm uppercase tracking-widest text-navy dark:text-white/80 mb-8">Qué te llevás</h4>
            <ul class="space-y-5">
              {features.map(feature => (
                <li class="flex items-start gap-4 group">
                  <div class="mt-1 w-5 h-5 rounded-full bg-forest/20 flex items-center justify-center shrink-0 border border-forest/30 group-hover:bg-forest transition-colors">
                    <svg class="text-forest group-hover:text-white transition-colors" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="text-mist font-medium leading-tight">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- White-Label Block: Ahora como Add-on o Partner -->
    <div class="mt-16 max-w-4xl mx-auto reveal" style="transition-delay: 0.4s;">
      <div class="bg-gradient-to-r from-navy to-navy-light p-10 md:p-12 rounded-[2.5rem] flex flex-col md:flex-row items-center justify-between gap-8 text-white shadow-2xl relative overflow-hidden">
        <!-- Decoración interna -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
        
        <div class="relative z-10">
          <div class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-white text-[10px] font-bold uppercase mb-4 tracking-wider border border-white/20">Partners</div>
          <h3 class="text-2xl md:text-3xl font-bold mb-3 text-white">¿Comercializás energía?</h3>
          <p class="text-white/70 max-w-xl">
             Llevá la claridad de EnergyOS a tu cartera bajo tu propia marca. Misma capa, tu logo.
          </p>
        </div>
        <div class="relative z-10 shrink-0">
          <a href="#contacto" data-plan="white-label" class="cta-plan-trigger inline-block px-10 py-4 bg-white text-navy rounded-2xl font-bold hover:bg-forest hover:text-white transition-all shadow-xl">Hablar de alianza</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ monthlyPrice, annualMonthlyEquivalent, annualPrice }}>
  function setupPricing() {
    const toggle = document.getElementById('pricing-toggle');
    const knob = document.getElementById('toggle-knob');
    const priceValue = document.getElementById('price-value');
    const pricePeriod = document.getElementById('price-period');
    const billingInfo = document.getElementById('billing-info');
    const labelMonthly = document.getElementById('label-monthly');
    const labelAnnual = document.getElementById('label-annual');

    let isAnnual = false;

    function updatePricing() {
      if (isAnnual) {
        knob.classList.add('translate-x-8');
        priceValue.textContent = annualMonthlyEquivalent.toString();
        pricePeriod.textContent = '/mes';
        billingInfo.textContent = `Facturado anualmente (USD ${annualPrice}/año)`;
        
        labelAnnual.classList.remove('text-mist');
        labelAnnual.classList.add('text-forest');
        
        labelMonthly.classList.remove('text-forest');
        labelMonthly.classList.add('text-mist');
      } else {
        knob.classList.remove('translate-x-8');
        priceValue.textContent = monthlyPrice.toString();
        pricePeriod.textContent = '/mes';
        billingInfo.textContent = 'Facturado mensualmente';
        
        labelMonthly.classList.remove('text-mist');
        labelMonthly.classList.add('text-forest');
        
        labelAnnual.classList.remove('text-forest');
        labelAnnual.classList.add('text-mist');
      }
    }

    toggle?.addEventListener('click', () => {
      isAnnual = !isAnnual;
      updatePricing();
    });

    // Init
    updatePricing();
  }

  setupPricing();
  document.addEventListener('astro:page-load', setupPricing);
</script>

<style>
  .pricing-toggle-btn {
    background-color: #e2e8f0; /* Color gris claro sólido */
    border: 1px solid #cbd5e1;
  }
  
  :global(.dark) .pricing-toggle-btn {
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  #pricing-toggle:hover #toggle-knob {
    box-shadow: 0 0 15px var(--color-forest);
  }
</style>
