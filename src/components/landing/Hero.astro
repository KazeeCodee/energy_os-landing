---
import { Image } from "astro:assets";
import sus1 from "../../assets/system/sus-1.jpeg";
import sus3 from "../../assets/system/sus-3.jpeg";
import sus6 from "../../assets/system/sus-6.jpeg";
---
<section class="relative min-h-[90vh] flex items-center pt-20 pb-12 overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 right-0 -z-10 w-[600px] h-[600px] bg-forest/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4 opacity-30 dark:opacity-50"></div>
  <div class="absolute bottom-0 left-0 -z-10 w-[400px] h-[400px] bg-navy/10 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4 opacity-30 dark:opacity-50"></div>

  <div class="container mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <!-- Columna Izquierda -->
    <div class="max-w-2xl reveal">
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-navy/5 dark:bg-white/5 border border-navy/10 dark:border-white/10 text-navy dark:text-forest text-xs font-semibold uppercase tracking-wider mb-6 reveal" style="transition-delay: 0.1s;">
        Inteligencia para el MEM
      </div>

      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6 tracking-tight reveal" style="transition-delay: 0.2s;">
        Si estás en el MEM y no tenés esto, estás tomando decisiones <span class="inline-block px-1 bg-gradient-to-r from-forest to-cyan-400 bg-clip-text text-transparent italic">a ciegas</span>.
      </h1>

      <p class="text-lg text-mist max-w-xl mb-8 leading-relaxed reveal" style="transition-delay: 0.3s;">
        EnergyOS te muestra en tiempo real si estás cumpliendo, cuánto estás pagando de más y qué decisiones tenés que tomar antes de perder plata.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 reveal" style="transition-delay: 0.4s;">
        <a href="#contacto" data-plan="demo" class="cta-plan-trigger px-8 py-4 bg-forest hover:bg-forest-dark text-white rounded-xl font-bold transition-all shadow-lg shadow-forest/20 text-center hover:scale-[1.02] active:scale-[0.98]">
          Quiero saber si estoy perdiendo plata
        </a>
        <a href="#pricing" class="px-8 py-4 bg-[var(--surface)] hover:bg-[var(--border)] border border-[var(--border)] rounded-xl font-bold transition-all text-center">
          Ver planes
        </a>
      </div>

      <div class="mt-12 flex items-center gap-4 text-sm text-mist/60 font-medium">
        <div class="flex -space-x-2">
          {[1, 2, 3, 4].map((i) => (
            <div class={`w-8 h-8 rounded-full border-2 border-[var(--background)] bg-slate-400 dark:bg-slate-800 flex items-center justify-center text-[10px] text-white`}>GU</div>
          ))}
        </div>
        <span>+100 Grandes Usuarios ya operan con claridad</span>
      </div>
    </div>

    <!-- Columna Derecha: Dashboard UI -->
    <div class="relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-forest to-forest-light rounded-2xl blur opacity-10 dark:opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
      
      <div class="relative bg-[var(--surface)] border border-[var(--border)] rounded-2xl overflow-hidden shadow-2xl backdrop-blur-sm">
        <!-- Header del Mockup -->
        <div class="bg-navy px-6 py-4 flex items-center justify-between border-b border-white/10">
          <div class="flex gap-2">
            <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow-400"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-forest"></div>
          </div>
          <div class="text-[10px] uppercase font-bold tracking-widest text-white/60">Tu operación, en claro</div>
        </div>

        <!-- Contenido del Mockup -->
        <div class="relative w-full aspect-video bg-[var(--background)] overflow-hidden">
          <Image src={sus3} alt="Resumen de Operación" class="absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-1000 hero-carousel-img" />
          <Image src={sus1} alt="Exposición Spot" class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 hero-carousel-img" />
          <Image src={sus6} alt="Historia Energética" class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 hero-carousel-img" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initCarousel() {
    const images = document.querySelectorAll('.hero-carousel-img');
    if (images.length === 0) return;
    
    let currentIndex = 0;
    // Clear any existing interval if the script runs multiple times
    if (window.heroCarouselInterval) clearInterval(window.heroCarouselInterval);
    
    window.heroCarouselInterval = setInterval(() => {
      images[currentIndex].classList.remove('opacity-100');
      images[currentIndex].classList.add('opacity-0');
      
      currentIndex = (currentIndex + 1) % images.length;
      
      images[currentIndex].classList.remove('opacity-0');
      images[currentIndex].classList.add('opacity-100');
    }, 4000);
  }

  initCarousel();
  document.addEventListener('astro:page-load', initCarousel);
</script>
