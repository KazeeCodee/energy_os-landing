---
import CustomSelect from "../ui/CustomSelect.astro";

const TIPO_EMPRESA_OPTIONS = [
  { value: "gran_usuario", label: "Gran Usuario en MEM" },
  { value: "gudi", label: "GUDI (compra a distribuidora)" },
  { value: "comercializador", label: "Comercializador MATER" },
  { value: "otro", label: "Otro" },
];

const ROL_OPTIONS = [
  { value: "cfo", label: "CFO / Finanzas" },
  { value: "operaciones", label: "Operaciones" },
  { value: "legal", label: "Legal / Regulatorio" },
  { value: "compras", label: "Compras / Energía" },
  { value: "otro", label: "Otro" },
];

---
<section id="contacto" class="py-24 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute top-1/2 left-0 -z-10 w-[500px] h-[500px] bg-forest/10 rounded-full blur-[120px] -translate-y-1/2 -translate-x-1/2 opacity-30"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <!-- Left: Info -->
        <div class="reveal">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-forest/5 text-forest text-[11px] font-bold uppercase tracking-[0.2em] mb-6 border border-forest/10">
            Contacto
          </div>
          <h2 class="text-4xl md:text-5xl font-bold mb-8 tracking-tight leading-tight text-[var(--text-main)]">
            Veamos cuánto estás <span class="text-forest italic">perdiendo</span>.
          </h2>
          <p class="text-mist text-lg mb-12 max-w-md leading-relaxed">
            Dejanos tus datos y te mostramos en concreto dónde estás expuesto y cuánto se puede recuperar.
          </p>
          
          <div class="grid grid-cols-1 gap-4 sm:gap-6">
            <div class="p-6 rounded-2xl bg-forest/5 border border-forest/10 hover:border-forest/20 transition-all group reveal-left" style="transition-delay: 0.3s;">
              <div class="w-12 h-12 rounded-xl bg-forest/10 flex items-center justify-center text-forest mb-4 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h4 class="text-xl font-bold mb-2 text-[var(--text-main)]">Tus datos, tuyos</h4>
              <p class="text-mist text-sm leading-relaxed">Lo que cargás se queda confidencial. Tu estrategia no se comparte ni se mezcla.</p>
            </div>

            <div class="p-6 rounded-2xl bg-navy/5 border border-navy/10 hover:border-navy/20 transition-all group reveal-left" style="transition-delay: 0.4s;">
              <div class="w-12 h-12 rounded-xl bg-navy/10 flex items-center justify-center text-navy mb-4 group-hover:scale-110 transition-transform dark:text-forest-light dark:bg-forest/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
              </div>
              <h4 class="text-xl font-bold mb-2 text-[var(--text-main)]">De una planta a una red</h4>
              <p class="text-mist text-sm leading-relaxed">Mismo nivel de claridad, sin importar el tamaño. La complejidad la absorbemos nosotros.</p>
            </div>

            <div class="p-6 rounded-2xl bg-forest/5 border border-forest/10 hover:border-forest/20 transition-all group reveal-left" style="transition-delay: 0.5s;">
              <div class="w-12 h-12 rounded-xl bg-forest/20 flex items-center justify-center text-forest mb-4 group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <h4 class="text-xl font-bold mb-2 text-[var(--text-main)]">Equipo que entiende</h4>
              <p class="text-mist text-sm leading-relaxed">Hablás con gente que conoce el mercado. No con un help-desk genérico.</p>
            </div>
          </div>
        </div>
        
        <!-- Right: Form Card -->
        <div class="reveal" style="transition-delay: 0.2s;">
          <div class="p-8 md:p-10 rounded-3xl bg-[var(--surface)] border border-[var(--border)] shadow-xl relative backdrop-blur-sm">
            <div class="absolute inset-0 rounded-3xl overflow-hidden pointer-events-none">
              <div class="absolute top-0 right-0 w-32 h-32 bg-forest/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            </div>
            
            <form id="contact-form" class="space-y-6 relative z-10" novalidate>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="name" class="text-sm font-semibold text-[var(--text-main)] ml-1">Nombre Completo *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="Ej: Juan Pérez"
                    class="w-full px-5 py-4 rounded-xl bg-[var(--background)] border border-[var(--border)] focus:border-forest focus:ring-2 focus:ring-forest/20 outline-none transition-all text-[var(--text-main)]"
                  />
                </div>
                <div class="space-y-2">
                  <label for="company" class="text-sm font-semibold text-[var(--text-main)] ml-1">Empresa</label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    placeholder="Ej: Energía S.A."
                    class="w-full px-5 py-4 rounded-xl bg-[var(--background)] border border-[var(--border)] focus:border-forest focus:ring-2 focus:ring-forest/20 outline-none transition-all text-[var(--text-main)]"
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label for="email" class="text-sm font-semibold text-[var(--text-main)] ml-1">Email Corporativo *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="juan@empresa.com"
                  class="w-full px-5 py-4 rounded-xl bg-[var(--background)] border border-[var(--border)] focus:border-forest focus:ring-2 focus:ring-forest/20 outline-none transition-all text-[var(--text-main)]"
                />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="tipo_empresa" class="text-sm font-semibold text-[var(--text-main)] ml-1">Tipo de empresa</label>
                  <CustomSelect
                    id="tipo_empresa"
                    name="tipo_empresa"
                    options={TIPO_EMPRESA_OPTIONS}
                    placeholder="Seleccionar..."
                  />
                </div>
                <div class="space-y-2">
                  <label for="rol" class="text-sm font-semibold text-[var(--text-main)] ml-1">Rol</label>
                  <CustomSelect
                    id="rol"
                    name="rol"
                    options={ROL_OPTIONS}
                    placeholder="Seleccionar..."
                  />
                </div>
              </div>


              <div class="space-y-2">
                <label for="message" class="text-sm font-semibold text-[var(--text-main)] ml-1">Mensaje *</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="4"
                  placeholder="Contanos en qué situación estás hoy."
                  class="w-full px-5 py-4 rounded-xl bg-[var(--background)] border border-[var(--border)] focus:border-forest focus:ring-2 focus:ring-forest/20 outline-none transition-all text-[var(--text-main)] resize-none"
                ></textarea>
              </div>

              <div id="form-feedback" class="hidden rounded-xl px-4 py-3 text-sm font-medium" role="status" aria-live="polite"></div>

              <button
                id="contact-submit"
                type="submit"
                class="w-full py-4 bg-forest hover:bg-forest-dark text-white rounded-xl font-bold transition-all shadow-lg shadow-forest/20 flex items-center justify-center gap-2 group hover:scale-[1.02] active:scale-[0.98] disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:scale-100"
              >
                <span id="contact-submit-label">Quiero ver mi exposición</span>
                <svg id="contact-submit-icon" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                <svg id="contact-submit-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path></svg>
              </button>
            </form>

            <script>
              import { supabase } from "../../db/supabase.js";

              function initContactForm() {
                const form = document.getElementById("contact-form") as HTMLFormElement | null;
                const feedback = document.getElementById("form-feedback");
                const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;
                const submitLabel = document.getElementById("contact-submit-label");
                const submitIcon = document.getElementById("contact-submit-icon");
                const submitSpinner = document.getElementById("contact-submit-spinner");

                if (!form) return;

                function setLoading(loading: boolean) {
                  if (!submitBtn || !submitLabel || !submitIcon || !submitSpinner) return;
                  submitBtn.disabled = loading;
                  submitLabel.textContent = loading ? "Enviando..." : "Quiero ver mi exposición";
                  submitIcon.classList.toggle("hidden", loading);
                  submitSpinner.classList.toggle("hidden", !loading);
                }

                form.addEventListener("input", () => {
                  feedback?.classList.add("hidden");
                });

                const REQUIRED_FIELDS = ["name", "email", "message"];

                function fieldElement(name: string): HTMLElement | null {
                  return form?.querySelector<HTMLElement>(`[name="${name}"]`) ?? null;
                }

                function markError(name: string) {
                  const el = fieldElement(name);
                  if (!el) return;
                  if (el.classList.contains("sr-only")) {
                    const trigger = el.closest(".custom-select-container")?.querySelector(".select-trigger") as HTMLElement | null;
                    trigger?.classList.add("field-error-trigger");
                  } else {
                    el.classList.add("field-error");
                  }
                }

                function clearError(name: string) {
                  const el = fieldElement(name);
                  if (!el) return;
                  if (el.classList.contains("sr-only")) {
                    const trigger = el.closest(".custom-select-container")?.querySelector(".select-trigger") as HTMLElement | null;
                    trigger?.classList.remove("field-error-trigger");
                  } else {
                    el.classList.remove("field-error");
                  }
                }

                function clearAllErrors() {
                  REQUIRED_FIELDS.forEach(clearError);
                }

                function scrollToField(name: string) {
                  const el = fieldElement(name);
                  if (!el) return;
                  const target = el.classList.contains("sr-only")
                    ? (el.closest(".custom-select-container") as HTMLElement | null)
                    : el;
                  target?.scrollIntoView({ behavior: "smooth", block: "center" });
                }

                REQUIRED_FIELDS.forEach((n) => {
                  const el = fieldElement(n);
                  if (!el) return;
                  el.addEventListener("input", () => clearError(n));
                });


                form.addEventListener("submit", async (e) => {
                  e.preventDefault();
                  if (feedback) feedback.classList.add("hidden");

                  const data = new FormData(form);
                  const payload = {
                    name: String(data.get("name") || "").trim(),
                    company: String(data.get("company") || "").trim() || null,
                    email: String(data.get("email") || "").trim(),
                    message: String(data.get("message") || "").trim(),
                    tipo_empresa: String(data.get("tipo_empresa") || "").trim() || null,
                    rol: String(data.get("rol") || "").trim() || null,
                  };

                  clearAllErrors();
                  const missing: string[] = [];
                  if (!payload.name) missing.push("name");
                  if (!payload.email) missing.push("email");
                  if (!payload.message) missing.push("message");

                  if (missing.length > 0) {
                    missing.forEach(markError);
                    scrollToField(missing[0]);
                    if (feedback) {
                      feedback.textContent = "Complete los campos marcados en rojo.";
                      feedback.classList.remove("hidden");
                      feedback.className = "rounded-xl px-4 py-3 text-sm font-medium bg-red-500/10 text-red-500 border border-red-500/20";
                    }
                    return;
                  }

                  setLoading(true);
                  const { error } = await supabase.from("contact_messages").insert(payload);
                  setLoading(false);

                  if (error) {
                    console.error("Supabase insert error:", error);
                    const msg =
                      error.code === "23514"
                        ? "Algún campo no cumple el formato requerido."
                        : error.code === "22001"
                          ? "Algún campo excede la longitud máxima."
                          : "No pudimos enviar su mensaje en este momento. Por favor, intente nuevamente más tarde.";
                    
                    window.dispatchEvent(
                      new CustomEvent("show-feedback-modal", {
                        detail: {
                          type: "error",
                          title: "Error de envío",
                          message: msg,
                        },
                      }) as any
                    );
                    return;
                  }

                  window.dispatchEvent(
                    new CustomEvent("show-feedback-modal", {
                      detail: {
                        type: "success",
                        title: "¡Mensaje enviado!",
                        message:
                          "Gracias por contactarnos. Nuestro equipo revisará su mensaje y se pondrá en contacto a la brevedad.",
                      },
                    }) as any
                  );
                  form.reset();
                  clearAllErrors();
                  // Reset custom selects manually
                  form.querySelectorAll('select').forEach(select => {
                    select.dispatchEvent(new Event('change', { bubbles: true }));
                  });
                });
              }

              initContactForm();
              document.addEventListener('astro:page-load', initContactForm);
            </script>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>
