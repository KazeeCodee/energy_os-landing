---
import Layout from './Layout.astro';
import Navbar from '../components/landing/Navbar.astro';
import Footer from '../components/landing/Footer.astro';

interface Props {
  title: string;
  updatedAt: string;
}

const { title, updatedAt } = Astro.props;
---

<Layout title={`${title} | EnergyOS`}>
  <Navbar />
  
  <div class="relative pt-32 pb-8 overflow-hidden border-b border-[var(--border)]">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <a href="/" class="inline-flex items-center gap-2 text-forest hover:text-forest-dark transition-colors mb-4 font-medium text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Volver al inicio
        </a>
        <h1 class="text-4xl md:text-5xl font-bold text-[var(--text-main)] mb-6 tracking-tight">{title}</h1>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-forest/10 text-forest text-xs font-medium border border-forest/20 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          Última actualización: {updatedAt}
        </div>
      </div>
    </div>
  </div>

  <main class="container mx-auto px-6 max-w-4xl relative z-10 pt-16 pb-32">
    <div class="transition-colors">
      <div class="legal-content">
        <slot />
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  /* Restaurar estilos de tipografía que antes estaban en las etiquetas HTML */
  .legal-content h2 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--text-main);
  }
  
  /* El primer h2 no necesita tanto margen superior */
  .legal-content h2:first-of-type {
    margin-top: 1rem;
  }
  
  .legal-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--color-mist);
  }

  .legal-content ul {
    list-style-type: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }

  .legal-content ul li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-mist);
  }

  .legal-content ul li::before {
    content: "•";
    color: var(--color-forest);
    position: absolute;
    left: 0;
    font-weight: bold;
  }
  
  .legal-content strong {
    color: var(--text-main);
    font-weight: 600;
  }
</style>
